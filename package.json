{
  "name": "projectflare",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare-native lightweight project management for small teams.",
  "type": "module",
  "scripts": {
    "dev": "pnpm build && wrangler dev",
    "dev:ui": "vite --host 127.0.0.1",
    "build": "vite build",
    "deploy": "pnpm build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply projectflare --local",
    "db:migrate": "wrangler d1 migrations apply projectflare --remote",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@cloudflare/workers-types": "4.20260610.1",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "typescript": "5.9.3",
    "vite": "^8.0.16",
    "vitest": "4.1.8",
    "wrangler": "4.99.0"
  }
}
